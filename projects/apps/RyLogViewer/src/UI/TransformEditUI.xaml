<Window x:Class="RyLogViewer.TransformEditUI"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Title="Edit Transform" Width="450" Height="240"
	WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
	<Grid Margin="12">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="80"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<!-- Pattern Type -->
		<Label Grid.Row="0" Grid.Column="0" Content="Type:" VerticalAlignment="Center"/>
		<ComboBox Grid.Row="0" Grid.Column="1" x:Name="m_type" Margin="0,2">
			<ComboBoxItem Content="Substring"/>
			<ComboBoxItem Content="Wildcard"/>
			<ComboBoxItem Content="Regular Expression"/>
		</ComboBox>

		<!-- Match Expression -->
		<Label Grid.Row="1" Grid.Column="0" Content="Match:" VerticalAlignment="Center"/>
		<TextBox Grid.Row="1" Grid.Column="1" x:Name="m_match" Margin="0,2"/>

		<!-- Replace Expression -->
		<Label Grid.Row="2" Grid.Column="0" Content="Replace:" VerticalAlignment="Center"/>
		<TextBox Grid.Row="2" Grid.Column="1" x:Name="m_replace" Margin="0,2"/>

		<!-- Options -->
		<StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,6,0,4">
			<CheckBox x:Name="m_ignore_case" Content="Ignore Case" Margin="0,0,16,0" IsChecked="True"/>
			<CheckBox x:Name="m_active" Content="Active" Margin="0,0,16,0" IsChecked="True"/>
		</StackPanel>

		<!-- Buttons -->
		<StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
			<Button Content="OK" Width="80" Margin="4" IsDefault="True" Click="OK_Click"/>
			<Button Content="Cancel" Width="80" Margin="4" IsCancel="True"/>
		</StackPanel>
	</Grid>
</Window>
