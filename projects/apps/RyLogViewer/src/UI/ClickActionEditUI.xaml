<Window x:Class="RyLogViewer.ClickActionEditUI"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Title="Edit Click Action" Width="450" Height="280"
	WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
	<Grid Margin="12">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="85"/>
			<ColumnDefinition Width="*"/>
			<ColumnDefinition Width="Auto"/>
		</Grid.ColumnDefinitions>

		<!-- Pattern Type -->
		<Label Grid.Row="0" Grid.Column="0" Content="Type:" VerticalAlignment="Center"/>
		<ComboBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" x:Name="m_type" Margin="0,2">
			<ComboBoxItem Content="Substring"/>
			<ComboBoxItem Content="Wildcard"/>
			<ComboBoxItem Content="Regular Expression"/>
		</ComboBox>

		<!-- Match Expression -->
		<Label Grid.Row="1" Grid.Column="0" Content="Match:" VerticalAlignment="Center"/>
		<TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" x:Name="m_match" Margin="0,2"/>

		<!-- Executable -->
		<Label Grid.Row="2" Grid.Column="0" Content="Executable:" VerticalAlignment="Center"/>
		<TextBox Grid.Row="2" Grid.Column="1" x:Name="m_exe" Margin="0,2"/>
		<Button Grid.Row="2" Grid.Column="2" Content="..." Width="28" Margin="4,2" Click="BrowseExe_Click"/>

		<!-- Arguments -->
		<Label Grid.Row="3" Grid.Column="0" Content="Arguments:" VerticalAlignment="Center"/>
		<TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" x:Name="m_args" Margin="0,2"
			ToolTip="Use {0}, {1}, etc. for regex capture groups"/>

		<!-- Working Dir -->
		<Label Grid.Row="4" Grid.Column="0" Content="Working Dir:" VerticalAlignment="Center"/>
		<TextBox Grid.Row="4" Grid.Column="1" x:Name="m_working_dir" Margin="0,2"/>
		<Button Grid.Row="4" Grid.Column="2" Content="..." Width="28" Margin="4,2" Click="BrowseDir_Click"/>

		<!-- Options -->
		<CheckBox Grid.Row="5" Grid.Column="1" x:Name="m_active" Content="Active" Margin="0,6,0,4" IsChecked="True"/>

		<!-- Buttons -->
		<StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right">
			<Button Content="OK" Width="80" Margin="4" IsDefault="True" Click="OK_Click"/>
			<Button Content="Cancel" Width="80" Margin="4" IsCancel="True"/>
		</StackPanel>
	</Grid>
</Window>
